#!/bin/bash
set -xeuo pipefail

# install -Dpm0644 -t /usr/share/ "$SRCDIR/cache/homebrew.tar.zst"
# install -Dpm0644 -t /usr/share/flatpak/remotes.d/ "$SRCDIR/cache/flathub.flatpakrepo"

fc-cache --force --really-force --system-only --verbose # recreate font-cache to pick up the added fonts

tee "/usr/share/factory/etc/hostname" <<< "ubuntu-atomic"

glib-compile-schemas /usr/share/glib-2.0/schemas/
